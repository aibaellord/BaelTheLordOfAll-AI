# =============================================================================
# BAEL MCP Hub - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your API keys
# =============================================================================

# =============================================================================
# ESSENTIAL TIER
# =============================================================================

# Brave Search API Key (https://brave.com/search/api/)
BRAVE_API_KEY=

# GitHub Personal Access Token (https://github.com/settings/tokens)
GITHUB_TOKEN=

# =============================================================================
# POWER TIER
# =============================================================================

# PostgreSQL Configuration
POSTGRES_USER=bael
POSTGRES_PASSWORD=bael_secure_password
POSTGRES_DB=bael

# Slack Bot Token (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-
SLACK_TEAM_ID=

# =============================================================================
# ENHANCED TIER
# =============================================================================

# Exa API Key (https://exa.ai)
EXA_API_KEY=

# Firecrawl API Key (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# =============================================================================
# SPECIALIZED TIER - Google Services
# =============================================================================

# Google OAuth Credentials (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

# =============================================================================
# SPECIALIZED TIER - AWS Services
# =============================================================================

# AWS Credentials (https://aws.amazon.com/console/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================================================
# SPECIALIZED TIER - Cloudflare
# =============================================================================

# Cloudflare API Token (https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# =============================================================================
# SPECIALIZED TIER - Monitoring
# =============================================================================

# Sentry (https://sentry.io)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# Raygun (https://raygun.com)
RAYGUN_API_KEY=

# =============================================================================
# SPECIALIZED TIER - Productivity
# =============================================================================

# Linear (https://linear.app)
LINEAR_API_KEY=

# Notion (https://www.notion.so/my-integrations)
NOTION_API_KEY=

# Todoist (https://todoist.com/prefs/integrations)
TODOIST_API_TOKEN=

# =============================================================================
# SPECIALIZED TIER - Development
# =============================================================================

# E2B Sandbox (https://e2b.dev)
E2B_API_KEY=

# =============================================================================
# LOCAL PATHS
# =============================================================================

# Obsidian Vault Path (local directory)
OBSIDIAN_VAULT_PATH=./data/obsidian
