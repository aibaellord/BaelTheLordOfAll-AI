# BAEL - The Lord of All AI Agents
# Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# OpenRouter (Primary - Multi-model gateway)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic (Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (GPT models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Local Ollama (Self-hosted models)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# =============================================================================
# DEFAULT MODEL CONFIGURATION
# =============================================================================

# Primary model for general tasks
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
# Model for reasoning/analysis
REASONING_MODEL=anthropic/claude-sonnet-4-20250514
# Model for code generation
CODING_MODEL=anthropic/claude-sonnet-4-20250514
# Model for quick/simple tasks
FAST_MODEL=anthropic/claude-3-haiku-20240307
# Model for embedding generation
EMBEDDING_MODEL=openai/text-embedding-3-small

# Model temperature settings
DEFAULT_TEMPERATURE=0.7
REASONING_TEMPERATURE=0.3
CODING_TEMPERATURE=0.2
CREATIVE_TEMPERATURE=0.9

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (Primary database)
DATABASE_URL=postgresql://bael:bael_password@localhost:5432/bael
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (Caching & Sessions)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ChromaDB (Vector database)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=bael_memory

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================

# Server settings
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_DEBUG=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# =============================================================================
# SECURITY
# =============================================================================

# Secret keys (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=change_this_to_a_random_64_character_string_in_production
JWT_SECRET_KEY=another_random_64_character_string_for_jwt_tokens
API_KEY_SALT=salt_for_api_key_hashing

# Encryption
ENCRYPTION_KEY=32_character_base64_encoded_key

# Authentication
AUTH_ENABLED=true
AUTH_TOKEN_EXPIRY=3600
AUTH_REFRESH_TOKEN_EXPIRY=604800

# =============================================================================
# MEMORY & STORAGE
# =============================================================================

# Memory configuration
MEMORY_MAX_EPISODIC=10000
MEMORY_MAX_SEMANTIC=50000
MEMORY_MAX_PROCEDURAL=5000
MEMORY_CLEANUP_INTERVAL=3600

# File storage
STORAGE_PATH=/Volumes/SSD320/BaelTheLordOfAll-AI/data
TEMP_PATH=/Volumes/SSD320/BaelTheLordOfAll-AI/tmp
LOG_PATH=/Volumes/SSD320/BaelTheLordOfAll-AI/logs

# Upload limits
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=txt,md,py,js,ts,json,yaml,yml,csv

# =============================================================================
# BROWSER AUTOMATION
# =============================================================================

# Playwright configuration
BROWSER_TYPE=chromium
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# Proxy (optional)
BROWSER_PROXY_URL=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Search APIs
SERPER_API_KEY=your_serper_api_key
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Code execution
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_TIMEOUT=30
CODE_EXECUTION_MEMORY_LIMIT=512

# GitHub integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# =============================================================================
# MONITORING & TELEMETRY
# =============================================================================

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# Metrics
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Tracing
TRACING_ENABLED=true
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Sentry (Error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# DISTRIBUTED MODE
# =============================================================================

# Node configuration
NODE_ID=bael-node-1
NODE_ADDRESS=localhost
NODE_PORT=8081

# Cluster settings
CLUSTER_ENABLED=false
CLUSTER_DISCOVERY_METHOD=static
CLUSTER_NODES=localhost:8081,localhost:8082,localhost:8083

# =============================================================================
# VOICE INTERFACE
# =============================================================================

# Speech recognition
SPEECH_PROVIDER=local
SPEECH_LANGUAGE=en-US

# Text-to-speech
TTS_PROVIDER=local
TTS_VOICE=default
TTS_SPEED=1.0

# Wake word
WAKE_WORD=hey bael
WAKE_WORD_SENSITIVITY=0.5

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Development mode
DEV_MODE=true
HOT_RELOAD=true
MOCK_EXTERNAL_SERVICES=false

# Testing
TEST_DATABASE_URL=postgresql://bael:bael_password@localhost:5432/bael_test
TEST_REDIS_URL=redis://localhost:6379/1

# =============================================================================
# FEATURE FLAGS
# =============================================================================

FEATURE_SELF_IMPROVEMENT=true
FEATURE_EMOTIONAL_INTELLIGENCE=true
FEATURE_VOICE_INTERFACE=false
FEATURE_DISTRIBUTED_MODE=false
FEATURE_PLUGIN_SYSTEM=true
FEATURE_MCP_SERVER=true
FEATURE_KNOWLEDGE_GRAPH=true
FEATURE_WORKFLOW_ENGINE=true
