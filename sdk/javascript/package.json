{
  "name": "bael-sdk",
  "version": "2.1.0",
  "description": "Official TypeScript/JavaScript SDK for BAEL - The Lord of All AI Agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "docs": "typedoc --out docs src",
    "prepublish": "npm run build && npm run test"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rollup": "^3.25.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "typedoc": "^0.25.0"
  },
  "keywords": [
    "ai",
    "artificial-intelligence",
    "agent",
    "multi-agent",
    "orchestration",
    "bael",
    "sdk",
    "client",
    "typescript",
    "javascript"
  ],
  "author": "BAEL Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bael/bael-sdk-js"
  },
  "bugs": {
    "url": "https://github.com/bael/bael-sdk-js/issues"
  },
  "homepage": "https://docs.bael.ai",
  "engines": {
    "node": ">=16.0.0"
  }
}
